# Copy to .env.local and fill in. Never commit real secrets.

# --- Supabase (auto-injected by Vercel Marketplace in prod) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- NewsAPI ---
NEWSAPI_KEY=

# --- Stripe (auto-injected by Vercel Marketplace in prod) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# --- Cron auth ---
CRON_SECRET=

# --- Public site URL (used for Stripe redirects, OAuth callbacks) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Dev mode ---
# DEV_BYPASS_PAYWALL=1
